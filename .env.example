EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
EXPO_PUBLIC_SPOTIFY_CLIENT_ID=YOUR_SPOTIFY_CLIENT_ID

# Optional — UI/UX only: skip Spotify login + real load; use mock track pool; host can start with 1 player.
# EXPO_PUBLIC_SKIP_SPOTIFY=true

# Optional — web only. Deezer blocks browser CORS; point this at your deployed origin
# so local `expo start --web` can load previews, e.g. https://YOUR_APP.vercel.app/api/deezer-preview
# EXPO_PUBLIC_DEEZER_PREVIEW_PROXY_URL=https://YOUR_APP.vercel.app/api/deezer-preview
